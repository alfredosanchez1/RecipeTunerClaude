# Variables de Entorno para RecipeTuner
# Copia este archivo como .env y agrega tus API keys reales

# OpenAI API para funcionalidades de IA
OPENAI_API_KEY=tu_openai_api_key_aqui

# Google Cloud Vision para OCR (opcional)
GOOGLE_VISION_API_KEY=tu_google_vision_api_key_aqui

# WhatsApp Business API (opcional)
WHATSAPP_ACCESS_TOKEN=tu_whatsapp_token_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui

# Telegram Bot API (opcional)
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui

# SendGrid para email (opcional)
SENDGRID_API_KEY=tu_sendgrid_api_key_aqui